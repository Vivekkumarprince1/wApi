{
  "name": "whatsapp-saas-backend",
  "version": "1.0.0",
  "description": "Backend API for WhatsApp Business SaaS",
  "main": "dist/server.js",
  "scripts": {
    "tunnel": "node scripts/start-tunnel.js",
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon",
    "dev:local": "cross-env PORT=5001 USE_IN_MEMORY_DB=true SKIP_REDIS=true npx nodemon server.js",
    "worker": "node src/services/queueWorker.js",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:e2e": "jest tests/e2e",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "migrate:lean-gupshup": "node scripts/migrateLeanGupshupData.js",
    "seed": "node seeds/seed.js",
    "seed:dev": "USE_IN_MEMORY_DB=true node seeds/seed.js",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "bullmq": "^1.91.1",
    "cheerio": "^1.2.0",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.2.1",
    "google-auth-library": "^10.5.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.3",
    "localtunnel": "^2.0.2",
    "mongodb-memory-server": "^8.12.1",
    "mongoose": "^8.23.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "ngrok": "^5.0.0-beta.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.13",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "razorpay": "^2.9.6",
    "redis": "^4.7.1",
    "sequelize": "^6.37.8",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "validator": "^13.11.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.4.0",
    "axios": "^1.13.6",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "mock-jwks": "^3.3.5",
    "nock": "^14.0.11",
    "nodemon": "^3.1.14",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "directories": {
    "test": "tests"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}
