# Server Configuration
NODE_ENV=development
PORT=5001
FRONTEND_URL=http://localhost:3000

MONGODB_URI=mongodb://localhost:27017/wa_saas
USE_IN_MEMORY_DB=false

REDIS_URL=redis://127.0.0.1:6379

JWT_SECRET=your-secret-key-change-in-production

# Gupshup Partner + WhatsApp APIs
GUPSHUP_PARTNER_TOKEN=
GUPSHUP_PARTNER_EMAIL=
GUPSHUP_PARTNER_CLIENT_SECRET=
GUPSHUP_PARTNER_TOKEN_TTL_MS=82800000
GUPSHUP_API_KEY=
GUPSHUP_APP_ID=
GUPSHUP_SOURCE_NUMBER=
GUPSHUP_PARTNER_BASE_URL=https://partner.gupshup.io
GUPSHUP_API_BASE_URL=https://api.gupshup.io
GUPSHUP_DEFAULT_REGION=IN
GUPSHUP_WEBHOOK_IPS=

# BSP Onboarding callback
GUPSHUP_EMBED_CALLBACK_URL=http://localhost:5001/api/v1/onboarding/bsp/callback
APP_URL=http://localhost:5001

# Security
ENCRYPTION_KEY=21fa7a5fec48a34ad274c00c12b46661276404edae6fc58f1af6002416d9afd4
TOKEN_ENCRYPTION_KEY=your-64-character-hex-encryption-key-here
SKIP_WEBHOOK_IP_CHECK=false

START_WORKER=false
START_ANALYTICS_CRON=false

# BSP Features
BSP_ONLY=true
BSP_GLOBAL_MESSAGING_DISABLED=false
BSP_HEALTH_INTERVAL_MS=300000

# Widget and API URLs
API_URL=https://api.wapi.com/api/v1
WIDGET_URL=https://widget.wapi.com

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
