{
  "name": "api-gateway",
  "version": "2.0.0",
  "description": "Pure API Gateway for wApi microservices (http-proxy-middleware router)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_OPTIONS=--max-old-space-size=2048 node --import tsx src/index.ts",
    "build": "NODE_OPTIONS=--max-old-space-size=2048 tsc",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "smoke:routes": "node --import tsx scripts/smoke-routes.ts"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.22.2",
    "helmet": "^7.2.0",
    "http-proxy-middleware": "^3.0.5",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "tsx": "^4.22.3",
    "typescript": "^5.7.3"
  }
}
