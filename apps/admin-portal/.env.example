# ── Admin Portal (apps/admin-portal) ──────────────────────────────────────
# Runs standalone on port 3100; deployed at admin.wapi.in

PORT=3100
NODE_ENV=development

# Branding
NEXT_PUBLIC_APP_NAME=wApi Super Admin
NEXT_PUBLIC_APP_URL=http://localhost:3100

# ── Auth (separate cookie; never reuse the customer auth_token) ───────────
# JWT_SECRET MUST match the value used by the gateway/core-server so that
# impersonation tokens minted by core-server are accepted downstream.
JWT_SECRET=your_jwt_secret_here
ADMIN_COOKIE_NAME=admin_token
# Admin session lifetime (seconds). Default 8h.
ADMIN_SESSION_TTL=28800

# ── Direct MongoDB reads (Rule #4) ────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/wa_saas
MONGODB_URI_BILLING=mongodb://localhost:27017/wapi_billing
MONGODB_URI_CAMPAIGN=mongodb://localhost:27017/wa_campaigns
MONGODB_URI_AUTOMATION=mongodb://localhost:27017/wapi_automation

# ── Gateway writes (Rule #5) ──────────────────────────────────────────────
# All mutations route through the gateway to preserve events/BullMQ/audit.
GATEWAY_URL=http://localhost:5001
INTERNAL_SERVICE_SECRET=your_internal_service_secret_here

# ── Service URLs for the Monitoring Center (optional; default to localhost) ─
CORE_SERVER_URL=http://localhost:5005
BILLING_SERVICE_URL=http://localhost:3003
CAMPAIGN_SERVICE_URL=http://localhost:3002
AUTOMATION_SERVICE_URL=http://localhost:3001
WEBSOCKET_SERVICE_URL=http://localhost:4000

# ── Impersonation hand-off ────────────────────────────────────────────────
# Where to send the admin after minting an impersonation session.
CUSTOMER_PORTAL_URL=http://localhost:3000
# Parent domain for the shared impersonation cookie (prod only, e.g. .wapi.in).
# Leave empty in local dev (cross-port localhost cannot share a cookie).
IMPERSONATION_COOKIE_DOMAIN=

# Optional: comma-separated dev origins to silence cross-origin warnings
# ALLOWED_DEV_ORIGINS=admin.localhost

# Used by monitoring and account-deletion flows.
GUPSHUP_PARTNER_PASSWORD=
BUSINESS_VERIFICATION_PROVIDER=hybrid
AUTH_TOKEN_TTL=7d
