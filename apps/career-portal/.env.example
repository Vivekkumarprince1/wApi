# Server-only MongoDB replica-set connection used by Prisma.
MONGODB_URI="mongodb://USERNAME:PASSWORD@HOST/DATABASE?retryWrites=true&w=majority"

# Better Auth secret: generate a high-entropy value for each environment.
BETTER_AUTH_SECRET="replace-with-at-least-32-random-characters"
BETTER_AUTH_URL="http://localhost:3001"

# Canonical public application origin.
APP_URL="http://localhost:3001"

# Optional Google OAuth. Register the callback URL as
# http://localhost:3001/api/auth/callback/google for local development.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED="true"

# Optional email delivery configuration.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_REPLY_TO=""

# Optional Cloudinary integration.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Required for contract submission. Generate 32 random bytes encoded as base64.
# Never reuse this key across environments or commit its value.
CONTRACT_ENCRYPTION_KEY=""

# Required before enabling outbound webhooks. Generate 32 random bytes encoded as base64.
WEBHOOK_ENCRYPTION_KEY=""

# Optional reCAPTCHA integration.
RECAPTCHA_SECRET_KEY=""
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""

# Optional external log/error/metric collector and protected Prometheus scrape token.
OBSERVABILITY_HTTP_ENDPOINT=""
OBSERVABILITY_HTTP_TOKEN=""
METRICS_TOKEN=""

# Production upload scanner. Expected response: {"clean":true}.
MALWARE_SCAN_URL=""
MALWARE_SCAN_TOKEN=""

# Set true in production after privileged users have enrolled TOTP.
REQUIRE_PRIVILEGED_MFA="true"

# Optional Upstash-compatible Redis REST endpoint for cross-replica rate limits.
RATE_LIMIT_REST_URL=""
RATE_LIMIT_REST_TOKEN=""

# Dual-application Playwright parity environment.
MERN_BASE_URL="http://localhost:5173"
NEXT_BASE_URL="http://localhost:3001"

# Seeded authenticated Playwright users and an open job identifier.
E2E_ADMIN_EMAIL=""
E2E_ADMIN_PASSWORD=""
E2E_CANDIDATE_EMAIL=""
E2E_CANDIDATE_PASSWORD=""
E2E_JOB_IDENTIFIER=""
