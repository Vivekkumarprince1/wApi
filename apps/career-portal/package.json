{
  "name": "connectsphere-careers",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "dev": "next dev --turbopack -p 3001",
    "build": "prisma generate && next build --webpack",
    "start": "next start -p ${PORT:-3001}",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:parity": "playwright test tests/e2e/parity",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "env:from-mern": "node scripts/map-legacy-env.mjs",
    "auth:migrate": "dotenv -e .env.local -- node scripts/migrate-legacy-auth.mjs",
    "auth:migrate:apply": "dotenv -e .env.local -- node scripts/migrate-legacy-auth.mjs --apply",
    "auth:normalize-enums": "dotenv -e .env.local -- node scripts/normalize-auth-enums.mjs",
    "auth:normalize-enums:apply": "dotenv -e .env.local -- node scripts/normalize-auth-enums.mjs --apply",
    "prisma:generate": "dotenv -e .env.local -- prisma generate",
    "prisma:validate": "dotenv -e .env.local -- prisma validate",
    "prisma:format": "dotenv -e .env.local -- prisma format",
    "prisma:push": "dotenv -e .env.local -- prisma db push",
    "backfill:jobs": "dotenv -e .env.local -- node scripts/backfill-jobs.mjs",
    "backfill:jobs:apply": "dotenv -e .env.local -- node scripts/backfill-jobs.mjs --apply",
    "backfill:hired-employees": "dotenv -e .env.local -- node scripts/backfill-hired-employees.mjs",
    "backfill:hired-employees:apply": "dotenv -e .env.local -- node scripts/backfill-hired-employees.mjs --apply",
    "backfill:employee-master": "dotenv -e .env.local -- node scripts/backfill-employee-master.mjs",
    "backfill:employee-master:apply": "dotenv -e .env.local -- node scripts/backfill-employee-master.mjs --apply",
    "seed:retention-policies": "dotenv -e .env.local -- node scripts/seed-retention-policies.mjs",
    "worker:outbox": "dotenv -e .env.local -- node scripts/outbox-worker.mjs",
    "worker:outbox:once": "dotenv -e .env.local -- node scripts/outbox-worker.mjs --once",
    "privacy:retention": "dotenv -e .env.local -- node scripts/privacy-retention.mjs",
    "privacy:retention:apply": "dotenv -e .env.local -- node scripts/privacy-retention.mjs --apply"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "@radix-ui/react-slot": "1.3.0",
    "@tanstack/react-form": "1.33.1",
    "@tanstack/react-query": "5.101.2",
    "bcryptjs": "3.0.3",
    "better-auth": "1.6.23",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.24.0",
    "mammoth": "^1.12.0",
    "motion": "12.42.2",
    "next": "16.2.10",
    "nodemailer": "^9.0.3",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.19.1",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.0",
    "prisma": "6.19.3",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}