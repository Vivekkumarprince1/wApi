generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

type Permissions {
  canGenerateCertificate          Boolean @default(false)
  canGenerateOfferLetter          Boolean @default(false)
  canCreateJob                    Boolean @default(false)
  canManageJobs                   Boolean @default(false)
  canViewApplicants               Boolean @default(false)
  canManageReviews                Boolean @default(false)
  canManageEmployees              Boolean @default(false)
  canManageRecommendations        Boolean @default(false)
  canManageCandidateCollaboration Boolean @default(false)
  canManageCommunications         Boolean @default(false)
  canAccessDashboard              Boolean @default(false)
  canManageInterviews             Boolean @default(false)
  canManageAttendance             Boolean @default(false)
  canManageLeave                  Boolean @default(false)
  canManagePayroll                Boolean @default(false)
  canManageExits                  Boolean @default(false)
  canManageDocuments              Boolean @default(false)
  canVerifyDocuments              Boolean @default(false)
  canManagePrivacy                Boolean @default(false)
  canManageIntegrations           Boolean @default(false)
  canViewReports                  Boolean @default(false)
}

type HrContact {
  name  String?
  email String?
  phone String?
}

type JobQuestion {
  id           String?      @map("_id") @db.ObjectId
  questionText String
  questionType QuestionType
  required     Boolean      @default(false)
  options      String[]
  maxRating    Int          @default(5)
  order        Int          @default(0)
}

type QuestionAnswer {
  id                 String?       @map("_id") @db.ObjectId
  questionId         String?       @db.ObjectId
  questionText       String?
  questionType       QuestionType?
  answer             Json?
  fileUrl            String?
  cloudinaryPublicId String?
}

type OfferExtension {
  id                    String?   @map("_id") @db.ObjectId
  oldValidUntil         DateTime?
  newValidUntil         DateTime?
  oldStartDate          DateTime?
  newStartDate          DateTime?
  notes                 String?
  previousOfferSnapshot Json?
  updatedOfferSnapshot  Json?
  extendedAt            DateTime  @default(now())
  extendedBy            String?   @db.ObjectId
}

type ContractAddress {
  street  String?
  city    String?
  state   String?
  zipCode String?
  country String? @default("India")
}

type EmergencyContact {
  name         String?
  relationship String?
  phone        String?
  email        String?
}

type IdentificationDocument {
  idType             IdentificationType?
  idNumber           String?
  documentUrl        String?
  cloudinaryPublicId String?
}

type PersonalInfo {
  dateOfBirth             DateTime?
  nationality             String?
  address                 ContractAddress?
  emergencyContact        EmergencyContact?
  identificationDocuments IdentificationDocument?
}

type BankingInfo {
  accountHolderName String?
  accountNumber     String?
  bankName          String?
  ifscCode          String?
  accountType       BankAccountType?
  branch            String?
}

type EmploymentDetails {
  position         String?
  department       String?
  salary           String?
  startDate        DateTime?
  joiningLocation  String?
  workType         WorkType?
  reportingManager String?
}

type WorkflowStage {
  completedAt DateTime?
  completedBy String?
  reason      String?
}

type WorkflowStages {
  submitted   WorkflowStage?
  underReview WorkflowStage? @map("under_review")
  approved    WorkflowStage?
  rejected    WorkflowStage?
}

type WorkflowStatus {
  currentStage WorkflowStageName? @default(SUBMITTED)
  submittedAt  DateTime?
  reviewedAt   DateTime?
  approvedAt   DateTime?
  rejectedAt   DateTime?
  stages       WorkflowStages?
}

type ContractDocument {
  id                 String?       @map("_id") @db.ObjectId
  documentType       DocumentType?
  fileName           String?
  fileUrl            String?
  cloudinaryPublicId String?
  uploadedAt         DateTime      @default(now())
}

type OnboardingDraftDocument {
  documentType       DocumentType?
  fileName           String?
  fileUrl            String?
  cloudinaryPublicId String?
  uploadedAt         DateTime      @default(now())
}

type AgreementTerms {
  termsAccepted         Boolean   @default(false)
  privacyPolicyAccepted Boolean   @default(false)
  acceptedAt            DateTime?
  ipAddress             String?
}

type JobUpdateDetails {
  oldRequirements     String[]
  newRequirements     String[]
  oldResponsibilities String[]
  newResponsibilities String[]
  changedFields       String[]
  updateType          JobUpdateType @default(OTHER)
}

model User {
  id                         String        @id @default(auto()) @map("_id") @db.ObjectId
  name                       String
  email                      String        @unique
  phoneNumber                String?
  password                   String?
  role                       UserRole      @default(USER)
  permissions                Permissions?
  assignedJobs               String[]      @db.ObjectId
  status                     UserStatus    @default(ACTIVE)
  positionLevel              PositionLevel @default(JUNIOR)
  isEmailVerified            Boolean       @default(false)
  emailVerificationOTP       String?
  emailVerificationOTPExpiry DateTime?
  passwordResetOTP           String?
  passwordResetOTPExpiry     DateTime?
  moreInfo                   String?       @db.ObjectId
  offerLetter                String?       @db.ObjectId
  department                 String?
  position                   String?
  reportingManager           String?
  employeeId                 String?       @unique
  terminatedAt               DateTime?
  terminationReason          String?
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime?
  image                      String?
  twoFactorEnabled           Boolean       @default(false)

  sessions                Session[]
  accounts                Account[]
  postedJobs              Job[]                @relation("PostedJobs")
  applications            Application[]
  offerLetters            OfferLetter[]
  contractsReviewed       EmploymentContract[] @relation("ContractReviewer")
  recommendationsMade     Recommendation[]     @relation("RecommendationRecommender")
  recommendationsReceived Recommendation[]     @relation("RecommendationCandidate")
  recommendationsReviewed Recommendation[]     @relation("RecommendationReviewer")
  reviews                 Review[]             @relation("ReviewAuthor")
  reviewsApproved         Review[]             @relation("ReviewApprover")
  reviewsRejected         Review[]             @relation("ReviewRejector")
  notifications           Notification[]
  auditLogs               AuditLog[]
  certificates            Certificate[]
  employeeRecord          Employee?
  candidateProfile        CandidateProfile?
  privacyRequestsReviewed DataSubjectRequest[] @relation("PrivacyRequestReviewer")
  roleAssignments         RoleAssignment[]
  twoFactor               TwoFactor?

  @@map("users")
}

model Department {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  code         String        @unique
  name         String        @unique
  description  String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  employees    Employee[]
  designations Designation[]

  @@index([isActive, name])
  @@map("departments")
}

model Designation {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  code         String        @unique
  name         String
  departmentId String?       @db.ObjectId
  department   Department?   @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  level        PositionLevel @default(JUNIOR)
  description  String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  employees    Employee[]

  @@unique([departmentId, name])
  @@index([isActive, name])
  @@map("designations")
}

model Employee {
  id                   String                 @id @default(auto()) @map("_id") @db.ObjectId
  userId               String                 @unique @db.ObjectId
  user                 User                   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  employeeCode         String                 @unique
  departmentId         String?                @db.ObjectId
  department           Department?            @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  designationId        String?                @db.ObjectId
  designation          Designation?           @relation(fields: [designationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  managerId            String?                @db.ObjectId
  manager              Employee?              @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  directReports        Employee[]             @relation("EmployeeManager")
  employmentStatus     EmploymentStatus       @default(ACTIVE)
  employmentType       EmploymentType?
  joinedAt             DateTime
  confirmedAt          DateTime?
  endedAt              DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  salaryStructures     SalaryStructure[]
  attendance           Attendance[]
  leaveRequests        LeaveRequest[]
  payslips             Payslip[]
  deductions           Deduction[]
  bonuses              Bonus[]
  reimbursements       Reimbursement[]
  resignations         Resignation[]
  terminations         Termination[]
  exitChecklists       ExitChecklist[]
  assets               Asset[]
  finalSettlements     FinalSettlement[]
  generatedDocs        GeneratedDocument[]
  documents            EmployeeDocument[]
  careerChanges        EmployeeCareerChange[]
  performanceReviews   PerformanceReview[]
  onboardingChecklists OnboardingChecklist[]

  @@index([departmentId, employmentStatus])
  @@index([designationId])
  @@index([managerId])
  @@map("employees")
}

model CandidateProfile {
  id              String                   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String                   @unique @db.ObjectId
  user            User                     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  primaryEmail    String
  normalizedEmail String                   @unique
  phone           String?
  retentionUntil  DateTime?
  anonymizedAt    DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  consents        ConsentRecord[]
  privacyRequests DataSubjectRequest[]
  savedJobs       SavedJob[]
  jobAlerts       JobAlert[]
  drafts          ApplicationDraft[]
  messages        CandidateMessage[]
  preferences     CommunicationPreference?

  @@index([retentionUntil])
  @@map("candidateprofiles")
}

model ConsentRecord {
  id                 String           @id @default(auto()) @map("_id") @db.ObjectId
  candidateProfileId String           @db.ObjectId
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  applicationId      String?          @db.ObjectId
  application        Application?     @relation(fields: [applicationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  purpose            ConsentPurpose
  legalBasis         String
  policyVersion      String
  source             String
  acceptedAt         DateTime         @default(now())
  withdrawnAt        DateTime?
  ipAddress          String?
  userAgent          String?

  @@index([candidateProfileId, purpose, acceptedAt(sort: Desc)])
  @@index([applicationId])
  @@map("consentrecords")
}

model DataSubjectRequest {
  id                 String                   @id @default(auto()) @map("_id") @db.ObjectId
  candidateProfileId String                   @db.ObjectId
  candidateProfile   CandidateProfile         @relation(fields: [candidateProfileId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  type               DataSubjectRequestType
  status             DataSubjectRequestStatus @default(REQUESTED)
  requestedAt        DateTime                 @default(now())
  dueAt              DateTime
  completedAt        DateTime?
  reviewedBy         String?                  @db.ObjectId
  reviewer           User?                    @relation("PrivacyRequestReviewer", fields: [reviewedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  notes              String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([status, dueAt])
  @@index([candidateProfileId, requestedAt(sort: Desc)])
  @@map("datasubjectrequests")
}

model RetentionPolicy {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  dataCategory  String   @unique
  retentionDays Int
  legalBasis    String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@map("retentionpolicies")
}

model Session {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(auto()) @map("_id") @db.ObjectId
  accountId             String
  providerId            String
  userId                String    @db.ObjectId
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

model TwoFactor {
  id                      String    @id @default(auto()) @map("_id") @db.ObjectId
  secret                  String    @unique
  backupCodes             String
  userId                  String    @unique @db.ObjectId
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  verified                Boolean   @default(true)
  failedVerificationCount Int       @default(0)
  lockedUntil             DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@map("twofactors")
}

model Job {
  id                  String             @id @default(auto()) @map("_id") @db.ObjectId
  slug                String?            @unique
  title               String
  company             String
  description         String
  requirements        String[]
  responsibilities    String[]
  location            String?
  type                EmploymentType?
  salary              String?
  department          String?
  position            String?
  reportingManager    String?
  imageUrl            String?
  cloudinaryPublicId  String?
  postedBy            String?            @db.ObjectId
  poster              User?              @relation("PostedJobs", fields: [postedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  isActive            Boolean            @default(true)
  isPublished         Boolean?           @default(false)
  requisitionId       String?            @unique
  headcount           Int                @default(1)
  applicationDeadline DateTime?
  publishAt           DateTime?
  unpublishAt         DateTime?
  archivedAt          DateTime?
  hrContact           HrContact?
  questions           JobQuestion[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @default(now())
  applications        Application[]
  certificates        Certificate[]
  recommendations     Recommendation[]
  notifications       Notification[]
  savedBy             SavedJob[]
  jobAlerts           JobAlert[]
  applicationDrafts   ApplicationDraft[]
  interviewRounds     InterviewRound[]

  @@index([isActive, createdAt(sort: Desc)])
  @@index([isActive, isPublished, createdAt(sort: Desc)])
  @@index([department])
  @@index([type])
  @@index([isPublished, applicationDeadline])
  @@index([archivedAt])
  @@map("jobs")
}

model Application {
  id                   String                @id @default(auto()) @map("_id") @db.ObjectId
  slug                 String?               @unique
  jobId                String                @db.ObjectId
  job                  Job                   @relation(fields: [jobId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  userId               String?               @db.ObjectId
  user                 User?                 @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fullName             String
  email                String
  phone                String
  resume               String?
  resumeUrl            String?
  cloudinaryPublicId   String?
  experience           String?
  education            String?
  skills               String[]
  coverLetter          String?
  isReferred           Boolean               @default(false)
  recommendationId     String?               @db.ObjectId
  questionAnswers      QuestionAnswer[]
  status               ApplicationStatus     @default(PENDING)
  ownerId              String?               @db.ObjectId
  tagIds               String[]              @db.ObjectId
  offerLetter          String?
  offerLetterId        String?               @db.ObjectId
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @default(now())
  offers               OfferLetter[]
  contracts            EmploymentContract[]
  recommendation       Recommendation?       @relation("ApplicationRecommendation", fields: [recommendationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  linkedRecommendation Recommendation?       @relation("RecommendationApplication")
  notifications        Notification[]
  consents             ConsentRecord[]
  interviewRounds      InterviewRound[]
  notes                CandidateNote[]
  activities           ApplicationActivity[]
  recruitingTasks      RecruitingTask[]
  messages             CandidateMessage[]

  @@index([jobId])
  @@index([userId])
  @@index([email])
  @@index([status, createdAt(sort: Desc)])
  @@index([jobId, status])
  @@map("applications")
}

model OfferLetter {
  id                 String                    @id @default(auto()) @map("_id") @db.ObjectId
  userId             String?                   @db.ObjectId
  user               User?                     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  applicationId      String?                   @db.ObjectId
  application        Application?              @relation(fields: [applicationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  candidateName      String
  email              String
  position           String
  department         String
  salary             String
  offerType          OfferType                 @default(JOB)
  payoutFrequency    String?
  startDate          DateTime
  endDate            DateTime?
  duration           String?
  joiningLocation    String?
  workType           WorkType                  @default(ON_SITE)
  benefits           String[]
  reportingManager   String?
  companyName        String                    @default("ConnectSphere")
  hrContactName      String?
  hrContactEmail     String?
  hrContactPhone     String?
  issuedBy           String                    @default("ConnectSphere")
  issuedOn           DateTime                  @default(now())
  status             OfferStatus               @default(PENDING)
  validUntil         DateTime
  shortId            String?                   @unique
  additionalNotes    String?
  extensionHistory   OfferExtension[]
  acceptedAt         DateTime?
  rejectedAt         DateTime?
  acceptanceToken    String?                   @unique
  acceptanceComments String?
  onboardingDraft    String?
  draftUpdatedAt     DateTime?
  draftDocuments     OnboardingDraftDocument[]
  contractId         String?                   @unique @db.ObjectId
  pdfBuffer          Bytes?
  pdfGeneratedAt     DateTime?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  contract           EmploymentContract?       @relation("OfferContract", fields: [contractId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  linkedContract     EmploymentContract?       @relation("ContractOffer")

  @@index([applicationId])
  @@index([email])
  @@map("offerletters")
}

model EmploymentContract {
  id                 String             @id @default(auto()) @map("_id") @db.ObjectId
  offerLetterId      String             @unique @db.ObjectId
  offerLetter        OfferLetter        @relation("ContractOffer", fields: [offerLetterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  applicationId      String?            @db.ObjectId
  application        Application?       @relation(fields: [applicationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  candidateName      String
  email              String
  phone              String?
  personalInfo       PersonalInfo?
  bankingInfo        BankingInfo?
  employmentDetails  EmploymentDetails?
  status             ContractStatus     @default(UNDER_REVIEW)
  workflowStatus     WorkflowStatus?
  acceptedAt         DateTime           @default(now())
  acceptanceComments String?
  reviewedBy         String?            @db.ObjectId
  reviewer           User?              @relation("ContractReviewer", fields: [reviewedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reviewedAt         DateTime?
  adminComments      String?
  documents          ContractDocument[]
  agreementTerms     AgreementTerms?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  offerBackReference OfferLetter?       @relation("OfferContract")

  @@index([email])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("employmentcontracts")
}

model Recommendation {
  id                    String               @id @default(auto()) @map("_id") @db.ObjectId
  recommender           String               @db.ObjectId
  recommenderUser       User                 @relation("RecommendationRecommender", fields: [recommender], references: [id], onDelete: NoAction, onUpdate: NoAction)
  recommenderId         String
  recommendedUser       String?              @db.ObjectId
  candidate             User?                @relation("RecommendationCandidate", fields: [recommendedUser], references: [id], onDelete: NoAction, onUpdate: NoAction)
  recommendedUserEmail  String
  recommendedUserName   String
  candidatePhone        String?
  relationship          String?
  consentConfirmed      Boolean              @default(false)
  invitationSentAt      DateTime?
  expiresAt             DateTime?
  jobId                 String               @db.ObjectId
  job                   Job                  @relation(fields: [jobId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  status                RecommendationStatus @default(PENDING)
  recommendationMessage String?
  adminNotes            String?
  reviewedBy            String?              @db.ObjectId
  reviewer              User?                @relation("RecommendationReviewer", fields: [reviewedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reviewedAt            DateTime?
  applicationId         String?              @unique @db.ObjectId
  application           Application?         @relation("RecommendationApplication", fields: [applicationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  applications          Application[]        @relation("ApplicationRecommendation")
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @default(now())

  @@index([recommender, status])
  @@index([recommendedUser])
  @@index([recommendedUserEmail, jobId])
  @@index([jobId, status])
  @@index([status, createdAt(sort: Desc)])
  @@map("recommendations")
}

model Review {
  id                 String       @id @default(auto()) @map("_id") @db.ObjectId
  userId             String       @db.ObjectId
  user               User         @relation("ReviewAuthor", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  userEmail          String
  userName           String
  rating             Int
  title              String
  content            String
  department         String?
  position           String?
  workType           WorkType?
  employmentDuration String?
  pros               String?
  cons               String?
  advice             String?
  status             ReviewStatus @default(PENDING)
  reviewerType       ReviewerType
  isAnonymous        Boolean      @default(false)
  moderatorNotes     String?
  approvedBy         String?      @db.ObjectId
  approver           User?        @relation("ReviewApprover", fields: [approvedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approvedAt         DateTime?
  rejectedBy         String?      @db.ObjectId
  rejector           User?        @relation("ReviewRejector", fields: [rejectedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rejectedAt         DateTime?
  rejectionReason    String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@index([userId])
  @@index([rating])
  @@map("reviews")
}

model Notification {
  id                   String               @id @default(auto()) @map("_id") @db.ObjectId
  userId               String               @db.ObjectId
  user                 User                 @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  type                 NotificationType
  title                String
  message              String
  relatedJobId         String?              @db.ObjectId
  job                  Job?                 @relation(fields: [relatedJobId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  relatedApplicationId String?              @db.ObjectId
  application          Application?         @relation(fields: [relatedApplicationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  isRead               Boolean              @default(false)
  readAt               DateTime?
  jobUpdateDetails     JobUpdateDetails?
  priority             NotificationPriority @default(MEDIUM)
  metadata             Json                 @default("{}")
  idempotencyKey       String?              @unique
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isRead, createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
  @@index([relatedJobId])
  @@map("notifications")
}

model OutboxEvent {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  idempotencyKey String       @unique
  topic          String
  aggregateType  String
  aggregateId    String       @db.ObjectId
  payload        Json
  status         OutboxStatus @default(PENDING)
  attempts       Int          @default(0)
  availableAt    DateTime     @default(now())
  processedAt    DateTime?
  lastError      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([status, availableAt])
  @@map("outboxevents")
}

model EmailDelivery {
  id             String              @id @default(auto()) @map("_id") @db.ObjectId
  idempotencyKey String              @unique
  template       String
  recipientHash  String
  status         EmailDeliveryStatus @default(PENDING)
  attempts       Int                 @default(0)
  providerId     String?
  nextAttemptAt  DateTime            @default(now())
  lastAttemptAt  DateTime?
  deliveredAt    DateTime?
  lastError      String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([status, nextAttemptAt])
  @@map("emaildeliveries")
}

model AuditLog {
  id             String      @id @default(auto()) @map("_id") @db.ObjectId
  actor          String      @db.ObjectId
  actorUser      User?       @relation(fields: [actor], references: [id], onDelete: NoAction, onUpdate: NoAction)
  actorRole      String
