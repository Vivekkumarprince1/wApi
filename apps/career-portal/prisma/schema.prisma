model IntegrationConnection {
  id              String              @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  provider        IntegrationProvider
  status          IntegrationStatus   @default(DISCONNECTED)
  encryptedConfig String?
  scopes          String[]
  lastCheckedAt   DateTime?
  lastError       String?
  createdBy       String              @db.ObjectId
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  webhooks        WebhookEndpoint[]

  @@index([provider, status])
  @@map("integrationconnections")
}

model WebhookEndpoint {
  id              String                 @id @default(auto()) @map("_id") @db.ObjectId
  integrationId   String?                @db.ObjectId
  integration     IntegrationConnection? @relation(fields: [integrationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  name            String
  url             String
  encryptedSecret String
  events          String[]
  isActive        Boolean                @default(true)
  failureCount    Int                    @default(0)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  deliveries      WebhookDelivery[]

  @@index([isActive])
  @@map("webhookendpoints")
}

model WebhookDelivery {
  id             String                @id @default(auto()) @map("_id") @db.ObjectId
  endpointId     String                @db.ObjectId
  endpoint       WebhookEndpoint       @relation(fields: [endpointId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  eventId        String                @unique
  eventType      String
  payload        Json
  status         WebhookDeliveryStatus @default(PENDING)
  attempts       Int                   @default(0)
  nextAttemptAt  DateTime              @default(now())
  responseStatus Int?
  responseBody   String?
  lastError      String?
  deliveredAt    DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([status, nextAttemptAt])
  @@map("webhookdeliveries")
}

model EmployeeDocument {
  id                 String                     @id @default(auto()) @map("_id") @db.ObjectId
  employeeId         String                     @db.ObjectId
  employee           Employee                   @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  type               EmployeeDocumentType
  name               String
  fileUrl            String
  cloudinaryPublicId String?
  status             DocumentVerificationStatus @default(PENDING)
  expiresAt          DateTime?
  verifiedBy         String?                    @db.ObjectId
  verifiedAt         DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@index([employeeId, type])
  @@index([status, expiresAt])
  @@map("employeedocuments")
}

model EmployeeCareerChange {
  id                String           @id @default(auto()) @map("_id") @db.ObjectId
  employeeId        String           @db.ObjectId
  employee          Employee         @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  type              CareerChangeType
  effectiveAt       DateTime
  fromDepartmentId  String?          @db.ObjectId
  toDepartmentId    String?          @db.ObjectId
  fromDesignationId String?          @db.ObjectId
  toDesignationId   String?          @db.ObjectId
  fromManagerId     String?          @db.ObjectId
  toManagerId       String?          @db.ObjectId
  notes             String?
  approvedBy        String?          @db.ObjectId
  createdAt         DateTime         @default(now())

  @@index([employeeId, effectiveAt(sort: Desc)])
  @@map("employeecareerchanges")
}

model PerformanceCycle {
  id        String                 @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  startsAt  DateTime
  endsAt    DateTime
  status    PerformanceCycleStatus @default(DRAFT)
  template  Json
  createdBy String                 @db.ObjectId
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  reviews   PerformanceReview[]

  @@index([status, startsAt])
  @@map("performancecycles")
}

model PerformanceReview {
  id            String               @id @default(auto()) @map("_id") @db.ObjectId
  cycleId       String               @db.ObjectId
  cycle         PerformanceCycle     @relation(fields: [cycleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  employeeId    String               @db.ObjectId
  employee      Employee             @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  managerId     String               @db.ObjectId
  status        ReviewWorkflowStatus @default(SELF_REVIEW)
  goals         Json
  selfReview    Json?
  managerReview Json?
  rating        Float?
  submittedAt   DateTime?
  completedAt   DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@unique([cycleId, employeeId])
  @@index([managerId, status])
  @@map("performancereviews")
}

model OnboardingChecklist {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  employeeId  String           @db.ObjectId
  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  name        String
  status      ChecklistStatus  @default(OPEN)
  startsAt    DateTime
  dueAt       DateTime?
  completedAt DateTime?
  createdBy   String           @db.ObjectId
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tasks       OnboardingTask[]

  @@index([employeeId, status])
  @@map("onboardingchecklists")
}

model OnboardingTask {
  id          String              @id @default(auto()) @map("_id") @db.ObjectId
  checklistId String              @db.ObjectId
  checklist   OnboardingChecklist @relation(fields: [checklistId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  title       String
  ownerId     String?             @db.ObjectId
  dueAt       DateTime?
  status      TaskStatus          @default(OPEN)
  evidence    Json?
  completedAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([ownerId, status, dueAt])
  @@map("onboardingtasks")
}

