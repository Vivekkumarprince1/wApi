# Service identity
SERVICE_NAME=campaign-service
PORT=3002
NODE_ENV=development

# Campaign-service-owned data and configuration
MONGO_URI=mongodb://localhost:27017/wa_campaigns
REDIS_URL=redis://localhost:6379

# Shared platform secrets: use the same values in every service that requires them.
JWT_SECRET=replace-with-generated-jwt-secret
INTERNAL_SERVICE_SECRET=replace-with-generated-internal-service-secret

# Dependency endpoints
BILLING_SERVICE_URL=http://localhost:3003
BSP_SERVICE_URL=http://localhost:3004
AUTOMATION_SERVICE_URL=http://localhost:3001
MONOLITH_URL=http://localhost:5001
