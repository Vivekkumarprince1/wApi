# Standalone WebSocket Microservice Configuration

# Port to run this microservice on (Avoid clashing with port 3004 of the core server)
PORT=4000

# Redis Database URL for Pub/Sub and Socket.io horizontal synchronization
REDIS_URL=redis://localhost:6379

# Shared JWT Secret key to authenticate client socket connections
JWT_SECRET=your-secret-key-change-in-production

# Core server internal address for user and permission checks
CORE_SERVER_URL=http://localhost:3004

# Secret for microservice-to-microservice secure REST calls
INTERNAL_SERVICE_SECRET=your_internal_service_secret_here

# Allowed origins for CORS (CORS is managed at the API Gateway level, but kept here for safety)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
