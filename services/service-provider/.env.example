# Service identity
SERVICE_NAME=service-provider
PORT=3004
NODE_ENV=development

# Shared platform secrets: use the same values in every service that requires them.
JWT_SECRET=replace-with-generated-jwt-secret
INTERNAL_SERVICE_SECRET=replace-with-generated-internal-service-secret
INTEGRATION_ENCRYPTION_KEY=replace-with-generated-integration-encryption-key

# Service-provider-owned data and configuration
MONGO_URI=mongodb://localhost:27017/wapi_bsp
REDIS_URL=redis://localhost:6379

# Dependency endpoints
MAIN_SERVICE_URL=http://localhost:5001
CAMPAIGN_SERVICE_URL=http://localhost:3002
BILLING_SERVICE_URL=http://localhost:3003

GUPSHUP_PARTNER_BASE_URL=https://partner.gupshup.io
GUPSHUP_API_BASE_URL=https://api.gupshup.io
GUPSHUP_PARTNER_EMAIL=
GUPSHUP_PARTNER_CLIENT_SECRET=
GUPSHUP_PARTNER_PASSWORD=
GUPSHUP_PARTNER_TOKEN=
GUPSHUP_WEBHOOK_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
AUTO_SYNC_WEBHOOKS_ON_BOOT=false

# Instagram channel configuration
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_API_VERSION=v25.0
INSTAGRAM_SCOPES=instagram_business_basic,instagram_business_manage_messages,instagram_business_manage_comments
INSTAGRAM_SUBSCRIBED_FIELDS=messages,message_reactions,message_echoes,comments
