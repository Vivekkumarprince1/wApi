# Service identity
SERVICE_NAME=webhook-ingestor
PORT=3013
NODE_ENV=development

# Webhook-ingestor-owned data and provider verification credentials
WEBHOOK_SECRET=replace-with-provider-webhook-secret
MONGO_URI=mongodb://127.0.0.1:27017/wapi
REDIS_URL=redis://127.0.0.1:6379
VERIFY_TOKEN=wapi-verify-token

# Shared platform secrets: use the same values in every service that requires them.
INTERNAL_SERVICE_SECRET=replace-with-generated-internal-service-secret
