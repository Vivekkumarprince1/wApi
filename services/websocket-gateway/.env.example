# Service identity
SERVICE_NAME=websocket-gateway
PORT=3009
NODE_ENV=development

# Websocket-gateway-owned data and configuration
MONGO_URI=mongodb://localhost:27017/wapi
REDIS_URL=redis://127.0.0.1:6379
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AUTH_SERVICE_URL=http://localhost:3006
AUTH_SERVICE_TIMEOUT_MS=2000

# Shared platform secret: use the same JWT_SECRET as token-issuing services.
JWT_SECRET=replace-with-generated-jwt-secret
