# ══════════════════════════════════════
# NEXT.JS CORE CONFIGURATION
# ══════════════════════════════════════
NODE_ENV=development
PORT=5005
BACKEND_PORT=3004
NEXT_PUBLIC_APP_URL=https://your-vercel-domain.vercel.app
ALLOWED_ORIGINS=https://your-vercel-domain.vercel.app,https://your-admin-domain.vercel.app,https://api-gateway-url.onrender.com

# ══════════════════════════════════════
# DATABASE & CACHE
# ══════════════════════════════════════
MONGODB_URI=mongodb://localhost:27017/wa_saas
REDIS_URL=redis://localhost:6379

# ══════════════════════════════════════
# SECURITY & AUTH
# ══════════════════════════════════════
JWT_SECRET=your_jwt_secret_here
INTERNAL_SERVICE_SECRET=your_internal_service_secret_here

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ══════════════════════════════════════
# BSP & WHATSAPP
# ══════════════════════════════════════
GUPSHUP_PARTNER_EMAIL=
GUPSHUP_PARTNER_CLIENT_SECRET=
GUPSHUP_PARTNER_BASE_URL=https://partner.gupshup.io
GUPSHUP_API_BASE_URL=https://api.gupshup.io
GUPSHUP_APP_ID=
GUPSHUP_SOURCE_NUMBER=

# Webhooks
WHATSAPP_WEBHOOK_URL=https://api-gateway-url.onrender.com/api/webhooks/whatsapp
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ══════════════════════════════════════
# EXTERNAL SERVICES
# ══════════════════════════════════════
AI_GEMINI_KEY=
CLOUDINARY_URL=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ══════════════════════════════════════
# EMAIL & APP CONFIG
# ══════════════════════════════════════
APP_NAME=wApi
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# ══════════════════════════════════════
# MICROSERVICES CONFIGURATION
# ══════════════════════════════════════
AUTOMATION_SERVICE_URL=https://automation-service.onrender.com
CAMPAIGN_SERVICE_URL=https://campaign-service.onrender.com
BILLING_SERVICE_URL=https://billing-service.onrender.com

# ══════════════════════════════════════
# FEATURE FLAGS
# ══════════════════════════════════════
ENABLE_AUTOMATION_ENGINE=true
START_CAMPAIGN_SCHEDULER=true
BUSINESS_VERIFICATION_MANDATORY=false
