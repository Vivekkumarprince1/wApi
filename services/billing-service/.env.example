# Service identity
SERVICE_NAME=billing-service
PORT=3003
NODE_ENV=development

# Billing-service-owned data and configuration
MONGO_URI=mongodb://localhost:27017/wapi_billing
REDIS_URL=redis://localhost:6379

# Shared platform secrets: use the same values in every service that requires them.
JWT_SECRET=replace-with-generated-jwt-secret
INTERNAL_SERVICE_SECRET=replace-with-generated-internal-service-secret

# Dependency endpoints and billing-provider credentials
BSP_SERVICE_URL=http://localhost:3004
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
