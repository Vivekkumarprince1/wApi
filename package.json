{
  "name": "wapi",
  "version": "1.0.0",
  "private": true,
  "description": "wApi monorepo — WhatsApp business platform (server gateway + microservices + frontend)",
  "workspaces": [
    "server",
    "automation-service",
    "campaign-service",
    "billing-service",
    "bsp-service",
    "frontend",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "start": "turbo run start --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
