{
  "name": "wapi",
  "version": "1.0.0",
  "private": true,
  "description": "wApi — WhatsApp BSP platform monorepo (npm workspace)",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "frontend",
    "api-gateway",
    "server",
    "automation-service",
    "campaign-service",
    "billing-service",
    "websocket-service",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build --concurrency=1",
    "build:legacy": "node controlled-build.js",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  }
}
