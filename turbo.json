{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": [
    ".env",
    ".env.local",
    ".env.production",
    "tsconfig.base.json"
  ],
  "globalEnv": [
    "NODE_ENV",
    "LOG_LEVEL",
    "LOGTAIL_SOURCE_TOKEN",
    "LOGTAIL_INGESTING_HOST",
    "SERVICE_NAME"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "inputs": [
        "src/**",
        "tsconfig.json",
        "package.json",
        "next.config.*",
        "nest-cli.json"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "start": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["build"]
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    },
    "@wapi/contracts#build": {
      "outputs": ["dist/**"],
      "inputs": ["src/**", "tsconfig.json"]
    }
  }
}
