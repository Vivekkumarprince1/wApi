# Northflank environment template for wApi.
# Create a secret group from these keys, replacing every placeholder before deploy.

NODE_ENV=production

# Public service URLs
CUSTOMER_PORTAL_URL=https://app.example.com
ADMIN_PORTAL_URL=https://admin.example.com
PUBLIC_API_URL=https://api.example.com
PUBLIC_SOCKET_URL=https://socket.example.com
PUBLIC_WEBHOOK_URL=https://webhooks.example.com
ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# Shared secrets
JWT_SECRET=replace-with-64-plus-random-characters
INTERNAL_SERVICE_SECRET=replace-with-64-plus-random-characters
INTEGRATION_ENCRYPTION_KEY=replace-with-32-byte-base64-or-hex-key
WEBHOOK_SECRET=replace-with-random-webhook-secret
VERIFY_TOKEN=replace-with-whatsapp-verify-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-with-whatsapp-verify-token

# Managed data services
REDIS_URL=redis://default:password@redis.internal:6379
MONGO_URI_AUTH=mongodb+srv://user:password@cluster.example/wapi
MONGO_URI_CONTACT=mongodb+srv://user:password@cluster.example/wapi
MONGO_URI_CHAT=mongodb+srv://user:password@cluster.example/wapi
MONGO_URI_BILLING=mongodb+srv://user:password@cluster.example/wapi_billing
MONGO_URI_CAMPAIGN=mongodb+srv://user:password@cluster.example/wapi_campaign
MONGO_URI_AUTOMATION=mongodb+srv://user:password@cluster.example/wapi_automation
MONGO_URI_BSP=mongodb+srv://user:password@cluster.example/wapi_bsp
MONGO_URI_WEBHOOK=mongodb+srv://user:password@cluster.example/wapi
MONGO_URI_WEBSOCKET=mongodb+srv://user:password@cluster.example/wapi

# Billing
RAZORPAY_KEY_ID=replace-with-razorpay-key-id
RAZORPAY_KEY_SECRET=replace-with-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=replace-with-razorpay-webhook-secret

# Gupshup / WhatsApp provider
GUPSHUP_PARTNER_BASE_URL=https://partner.gupshup.io
GUPSHUP_API_BASE_URL=https://api.gupshup.io
GUPSHUP_PARTNER_EMAIL=partner@example.com
GUPSHUP_PARTNER_CLIENT_SECRET=replace-with-gupshup-client-secret
GUPSHUP_WEBHOOK_SECRET=replace-with-gupshup-webhook-secret

# Optional auth and public integrations
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_FACEBOOK_APP_ID=
NEXT_PUBLIC_APP_NAME=wApi
NEXT_PUBLIC_BUSINESS_VERIFICATION_MANDATORY=false
NEXT_PUBLIC_GUPSHUP_DEFAULT_REGION=IN
