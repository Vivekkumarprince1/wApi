# Shared across all wApi services. Each service may have additional
# variables documented in its own folder.

# Better Stack / Logtail centralized logging.
# When both are set, every service ships JSON logs to Better Stack on top
# of stdout. Leave blank for stdout-only (safe for local dev).
LOGTAIL_SOURCE_TOKEN=
LOGTAIL_INGESTING_HOST=

# Log verbosity. Defaults to "debug" in dev, "info" in prod.
LOG_LEVEL=

# Optional override for the service name stamped on every log line.
# Each service has a sensible default (e.g. "campaign-service").
# SERVICE_NAME=
