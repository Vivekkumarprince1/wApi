  },
  "peerDependencies": {
    "@logtail/node": "^0.5.0",
    "@logtail/winston": "^0.5.0"
  },
  "peerDependenciesMeta": {
    "@logtail/node": {
      "optional": true
    },
    "@logtail/winston": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2"
  }
