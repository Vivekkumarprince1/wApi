{
  "name": "@wapi/contracts",
  "version": "0.1.0",
  "private": true,
  "description": "Shared request/response types and event payloads for wApi services.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
